# Vercel production env template — copy to .env.vercel.production (gitignored) before pulling live values.
# Pull live values: vercel env pull .env.vercel.production
# NEVER commit the pulled file; it will contain SUPABASE_SERVICE_ROLE_KEY and Stripe secrets.

APP_URL="https://your-production-domain"
VITE_AUTH_REDIRECT_ORIGIN="https://your-production-domain"
BACKEND_PROVIDER="supabase"
VITE_BACKEND_PROVIDER="supabase"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
VITE_PRICING_PAGE_ENABLED="true"
VITE_STRIPE_BILLING_ENABLED=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_STUDIO_MONTHLY=""
STRIPE_PRICE_ENTERPRISE_MONTHLY=""

# Firebase rollback (only when VITE_BACKEND_PROVIDER=firebase)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_APP_ID=
# FIREBASE_PROJECT_ID=
# FIREBASE_SERVICE_ACCOUNT_JSON=
