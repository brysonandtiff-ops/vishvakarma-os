{
  "name": "vishvakarma-os",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "browserslist": [
    "Chrome >= 90",
    "Firefox >= 88",
    "Safari >= 14",
    "iOS >= 14"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "preview:e2e": "vite build --mode e2e && vite preview --host 127.0.0.1 --port 4173",
    "preview:e2e:local": "vite build --mode e2e-local && vite preview --host 127.0.0.1 --port 4173",
    "build": "vite build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:routes": "vitest run src/routes.production.test.tsx",
    "test:e2e": "node scripts/run-e2e-gates.mjs",
    "test:e2e:auth": "pnpm exec playwright test --project=auth-gate",
    "test:e2e:app": "pnpm exec playwright test --project=app-smoke",
    "test:e2e:cross-browser": "node scripts/run-cross-browser-gates.mjs",
    "test:e2e:a11y": "node scripts/run-local-preview-playwright.mjs --project=accessibility-audit",
    "test:screenshots": "node scripts/run-screenshot-pack.mjs",
    "marketing:assets": "node scripts/run-local-preview-playwright.mjs --project=screenshot-pack marketing-asset-pack.spec.ts",
    "capture:page-references": "node scripts/run-page-reference-pack.mjs",
    "assets:apple-touch-icon": "node scripts/generate-apple-touch-icon.mjs",
    "assets:pwa-icons": "node scripts/sync-pwa-icon-svgs.mjs && node scripts/generate-apple-touch-icon.mjs",
    "test:e2e:install": "pnpm exec playwright install --with-deps chromium firefox webkit",
    "lint": "pnpm run lint:types && pnpm run lint:deps && pnpm run lint:structure",
    "lint:types": "tsgo -p tsconfig.check.json",
    "lint:deps": "biome lint --only=correctness/noUndeclaredDependencies",
    "lint:structure": "ast-grep scan",
    "contract:gates": "node scripts/quality/check-system-contract.mjs && node scripts/quality/check-forbidden-edges.mjs && node scripts/quality/check-build-gate.mjs",
    "test:anchors": "vitest run src/test/regressionAnchors.test.ts",
    "auth:gates": "node scripts/quality/check-auth-config-guard.mjs",
    "flawless:gates": "node scripts/quality/check-flawless-use-gates.mjs",
    "launch:evidence": "node scripts/quality/check-launch-evidence.mjs",
    "launch:evidence:strict": "node scripts/quality/check-launch-evidence.mjs --strict",
    "release:gates": "node scripts/verify-all.js",
    "release:gates:strict": "node scripts/verify-all.js --strict",
    "verify": "pnpm run lint && pnpm run contract:gates && pnpm run auth:gates && pnpm run flawless:gates && pnpm run launch:evidence && pnpm run test && pnpm run build",
    "verify:ci": "pnpm run verify && pnpm run test:routes",
    "ci": "pnpm run lint && pnpm run contract:gates && node scripts/quality/check-vercel-security.mjs && pnpm run launch:evidence && pnpm run test:coverage && pnpm run test:anchors && pnpm run test:routes && pnpm run build",
    "production:verify-env": "node scripts/production/verify-env.mjs",
    "setup:firebase-auth": "node scripts/setup-firebase-auth-config.mjs",
    "sync:firebase-preview-domain": "node scripts/setup-firebase-auth-config.mjs",
    "verify:firebase-auth-domains": "node scripts/verify-firebase-auth-domains.mjs",
    "verify:production-auth-flow": "node scripts/verify-production-auth-flow.mjs",
    "verify:live-auth-flow": "node scripts/verify-live-auth-flow.mjs --skip-interactive",
    "verify:live-auth-flow:interactive": "node scripts/verify-live-auth-flow.mjs",
    "setup:firebase-oauth": "node scripts/setup-firebase-oauth-providers.mjs",
    "setup:stripe": "node scripts/setup-stripe-products.mjs",
    "verify:stripe-billing": "node scripts/verify-stripe-billing.mjs",
    "setup:firebase-auth:full": "node scripts/setup-firebase-auth-config.mjs && npx -y firebase-tools@latest deploy --only auth --project gen-lang-client-0690161780 && node scripts/setup-firebase-auth-config.mjs && node scripts/setup-firebase-oauth-providers.mjs",
    "test:firebase-auth": "node scripts/test-firebase-auth-smoke.mjs --config-only",
    "test:firebase-auth:full": "node scripts/test-firebase-auth-smoke.mjs",
    "production:evidence": "node scripts/production/generate-evidence.mjs",
    "production:manual-evidence": "node scripts/production/generate-manual-evidence.mjs",
    "record:measure": "node scripts/world-record/measure-record.mjs",
    "deploy:vercel": "bash scripts/deploy-vercel.sh",
    "collab:server": "node --import tsx server/collab/presenceServer.ts",
    "collab:server:dev": "node --import tsx --watch server/collab/presenceServer.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-three/drei": "catalog:",
    "@react-three/fiber": "catalog:",
    "axios": "^1.13.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "embla-carousel-react": "^8.6.0",
    "eventsource-parser": "^3.0.6",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.10.0",
    "input-otp": "^1.4.2",
    "jszip": "^3.10.1",
    "ky": "^1.13.0",
    "lib0": "^0.2.117",
    "lucide-react": "^0.576.0",
    "motion": "^12.23.25",
    "next-themes": "^0.4.6",
    "qrcode": "^1.5.4",
    "react": "^18.0.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^18.0.0",
    "react-dropzone": "^14.3.8",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.66.0",
    "react-resizable-panels": "^2.1.8",
    "react-router": "^7.9.5",
    "react-router-dom": "^7.9.5",
    "recharts": "2.15.4",
    "sonner": "^2.0.7",
    "streamdown": "^1.4.0",
    "stripe": "^22.2.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "tailwindcss-intersect": "^2.2.0",
    "three": "catalog:",
    "vaul": "^1.1.2",
    "video-react": "^0.16.0",
    "ws": "^8.21.0",
    "y-indexeddb": "^9.0.12",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.31",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.39.5",
    "@axe-core/playwright": "^4.10.2",
    "@biomejs/biome": "2.4.5",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/container-queries": "^0.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jszip": "^3.4.1",
    "@types/node": "^24.2.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/video-react": "^0.15.8",
    "@typescript/native-preview": "7.0.0-dev.20251103.1",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.21",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.11",
    "tsx": "^4.22.4",
    "typescript": "~5.9.3",
    "vite": "npm:rolldown-vite@7.2.10",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.0.18"
  }
}
