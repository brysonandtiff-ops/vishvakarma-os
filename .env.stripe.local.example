# Vishvakarma.OS Stripe Billing local template
# Copy to .env.stripe.local, then paste real values from Stripe / Vercel.
# .env.stripe.local is ignored by git.

# Server-only Stripe key. Do not use a VITE_ prefix and do not commit the real value.
STRIPE_SECRET_KEY=replace-with-stripe-server-key

# Stripe webhook signing secret for /api/stripe/webhook.
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-signing-secret

# Created by: pnpm run setup:stripe
STRIPE_PRICE_STUDIO_MONTHLY=price_replace_with_studio_monthly_id
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_replace_with_enterprise_monthly_id

# App URL used for checkout success/cancel and billing portal return URLs.
APP_URL=http://127.0.0.1:5173

# Billing writes are expected to use Firebase in the current Vishvakarma production path.
BACKEND_PROVIDER=firebase
VITE_BACKEND_PROVIDER=firebase

# Required by api/_lib/verifyAuthToken.ts and api/_lib/billingBackend.ts.
FIREBASE_PROJECT_ID=replace-with-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"replace-with-firebase-project-id"}

# Client-side toggles belong in .env.local or Vercel env, not only this file.
# VITE_STRIPE_BILLING_ENABLED=true
# VITE_PRICING_PAGE_ENABLED=true
