rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    function isCollaborator() {
      return isSignedIn()
        && resource.data.collaborators != null
        && request.auth.uid in resource.data.collaborators;
    }

    function canReadProject() {
      return isOwner() || isCollaborator();
    }

    function canEditProject() {
      return isOwner() || isCollaborator();
    }

    function isOwnerOnCreate() {
      return isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin';
    }

    match /profiles/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
    }

    match /projects/{docId} {
      allow read: if canReadProject();
      allow create: if isOwnerOnCreate();
      allow update: if canEditProject();
      allow delete: if isOwner();

      match /collaborators/{userId} {
        allow read: if canReadProject();
        allow write: if isOwner();
      }
    }

    match /specs/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /registry/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /change_requests/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || isOwner();
    }

    match /releases/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /audit_logs/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /route_manifest/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
