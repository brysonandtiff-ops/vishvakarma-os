{
  "include": ["./api/**/*.ts"],
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["node", "vite/client", "react", "react-dom"],
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
