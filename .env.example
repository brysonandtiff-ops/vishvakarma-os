# Vishvakarma.OS environment template
# Copy this file to .env.local for local development or configure these variables in Vercel.

# Backend provider switch.
# Use firebase when Supabase quota is exhausted or when Firebase Auth + Firestore is the active backend.
# Supported values: supabase, firebase
VITE_BACKEND_PROVIDER=firebase

# ============================================================================
# Firebase Authentication (primary auth provider)
# ============================================================================
# Required when VITE_BACKEND_PROVIDER=firebase. Without them, sign-in is disabled.
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id

# Firebase Auth setup checklist:
# 1. In Firebase console > Authentication > Sign-in method, enable
#    "Email link (passwordless sign-in)".
# 2. Add your production and localhost preview URLs to the authorized domains.
# 3. Ensure the redirect URL (window.location.origin) is allowed.
# 4. Create a Firestore database while developing with the firebase provider.

# ============================================================================
# Supabase (legacy data backend: persistence, registry, releases, audit logs)
# ============================================================================
# Required when VITE_BACKEND_PROVIDER=supabase, or as the data layer alongside Firebase auth.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase data setup checklist:
# 1. Apply migrations in supabase/migrations before allowing real users.
# 2. Configure row-level security to match Firebase-authenticated identities.

# ============================================================================
# Local development
# ============================================================================
# Set to "true" in DEV to bypass the auth gate for local preview work.
# VITE_ALLOW_LOCAL_DEMO=true
