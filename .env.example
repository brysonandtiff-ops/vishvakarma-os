# Vishvakarma.OS environment template
# Copy this file to .env.local for local development or configure these variables in Vercel.

# E2E only (Playwright app-smoke project): set true in e2e build to access editor without auth when backend is unconfigured.
# VITE_E2E_ALLOW_LOCAL_ACCESS=true

# ============================================================================
# Backend provider (Supabase = production default; Firebase = rollback)
# ============================================================================
VITE_BACKEND_PROVIDER=supabase
BACKEND_PROVIDER=supabase

# ============================================================================
# Supabase Auth + Postgres (production default)
# ============================================================================
# Project ref: jyocvwipthswfcmvqgqe
VITE_SUPABASE_URL=https://jyocvwipthswfcmvqgqe.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only (Stripe webhooks, JWT verify — never prefix with VITE_)
SUPABASE_URL=https://jyocvwipthswfcmvqgqe.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Supabase setup (operator):
# npx supabase login
# npx supabase link --project-ref jyocvwipthswfcmvqgqe
# npx supabase db push
# node scripts/setup-supabase-auth-providers.mjs
# pnpm run test:supabase-auth:full

# ============================================================================
# Firebase Authentication + Firestore (rollback path)
# ============================================================================
# Set VITE_BACKEND_PROVIDER=firebase and fill these to roll back from Supabase.
# VITE_FIREBASE_API_KEY=your-firebase-api-key
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
# VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
# VITE_FIREBASE_APP_ID=your-firebase-app-id

# Firebase setup (operator — not inlined by Vite):
# pnpm run setup:firebase-auth:full   # email link + Google via firebase deploy --only auth
# pnpm run test:firebase-auth         # smoke-test email API + provider status

# Migration scripts (operator only — not used by the SPA):
# GOOGLE_APPLICATION_CREDENTIALS=path/to/firebase-service-account.json

# ============================================================================
# Marketing / launch
# ============================================================================
# Public pricing page at /pricing (nav link + route). Set true when launch copy is ready.
VITE_PRICING_PAGE_ENABLED=true

# Stripe checkout UI on /pricing and /profile
# VITE_STRIPE_BILLING_ENABLED=true

# ============================================================================
# Stripe Billing (server-only — never prefix with VITE_)
# ============================================================================
# Operator setup: STRIPE_SECRET_KEY=sk_test_... pnpm run setup:stripe
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_STUDIO_MONTHLY=
# STRIPE_PRICE_ENTERPRISE_MONTHLY=
# APP_URL=https://vishvakarma-os.vercel.app

# ============================================================================
# Local development
# ============================================================================
# Set to "true" in DEV to bypass the auth gate for local preview work.
# VITE_ALLOW_LOCAL_DEMO=true
