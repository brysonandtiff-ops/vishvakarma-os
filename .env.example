# Vishvakarma.OS environment template
# Copy this file to .env.local for local development or configure these variables in Vercel.

# Required for Supabase-backed persistence, registry, change requests, release records, and audit logs.
# The app runs in local-only mode without these values, but production deployments should set both.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
