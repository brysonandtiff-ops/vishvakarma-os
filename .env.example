# Vishvakarma.OS environment template
# Copy this file to .env.local for local development or configure these variables in Vercel.

# Required for Supabase-backed authentication, persistence, registry, change requests,
# release records, and audit logs.
# Production deployments must set both values.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Auth setup checklist:
# 1. Enable email link / OTP sign-in in Supabase Auth providers.
# 2. Add your production site URL in Supabase Auth URL Configuration.
# 3. Add localhost preview URLs for local development if needed.
# 4. Apply migrations in supabase/migrations before allowing real users.
