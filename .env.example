# Vishvakarma.OS environment template
# Copy this file to .env.local for local development or configure these variables in Vercel.

# Backend provider switch.
# Use firebase when Supabase quota is exhausted or when Firebase Auth + Firestore is the active backend.
# Supported values: supabase, firebase
VITE_BACKEND_PROVIDER=firebase

# Firebase Auth + Firestore configuration.
# Get these from Firebase Console → Project settings → General → Your apps → Web app config.
# Required when VITE_BACKEND_PROVIDER=firebase.
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=your-firebase-app-id

# Firebase setup checklist:
# 1. Create a Firebase project.
# 2. Add a Web app in Firebase Project settings.
# 3. Enable Authentication → Sign-in method → Email/Password.
# 4. Enable email link sign-in if using passwordless email links.
# 5. Add your deployed domain in Authentication → Settings → Authorized domains.
# 6. Create a Firestore database in production or test mode while developing.
# 7. Add matching environment variables to Vercel.

# Optional legacy Supabase backend values.
# Keep these only if VITE_BACKEND_PROVIDER=supabase.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Auth setup checklist:
# 1. Enable email link / OTP sign-in in Supabase Auth providers.
# 2. Add your production site URL in Supabase Auth URL Configuration.
# 3. Add localhost preview URLs for local development if needed.
# 4. Apply migrations in supabase/migrations before allowing real users.
